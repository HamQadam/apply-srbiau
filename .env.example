# Database Configuration
POSTGRES_USER=apply_user
POSTGRES_PASSWORD=apply_secret_password
POSTGRES_DB=apply_db

# Application Settings
DEBUG=false
DEBUG_OTP=false
NGINX_HTTP_PORT=80
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# SMS OTP Provider
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# LiteLLM — Stage-3 LLM enrichment job
# Supports any provider: OpenRouter, Groq, Azure, Ollama, …
# Switch provider by changing LITELLM_MODEL; no code changes needed.
# ─────────────────────────────────────────────────────────────

# Model string (passed directly to litellm.completion)
# Examples:
#   openrouter/meta-llama/llama-3.1-8b-instruct:free   (free tier, recommended)
#   openrouter/google/gemma-3-12b-it:free
#   groq/llama-3.1-8b-instant
#   ollama/llama3.2:3b                                  (self-hosted)
LITELLM_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct:free

# API key for your LiteLLM proxy or OpenRouter account
LITELLM_API_KEY=

# Optional: override the base URL (e.g. for a self-hosted LiteLLM proxy)
LITELLM_API_BASE=

# Set to "false" to disable the LLM enrichment step entirely
LITELLM_ENABLED=true

# Tuning (defaults are sensible; only change if needed)
LITELLM_MAX_TOKENS=256
LITELLM_TEMPERATURE=0.0
LITELLM_TIMEOUT=30
